<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:padding="6dp"
        android:background="@color/white">

        <Button
            android:id="@+id/btnRequestVoice"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="申请语音"
            android:textSize="11sp" />

        <Button
            android:id="@+id/btnAcceptVoice"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="同意"
            android:textSize="11sp" />

        <Button
            android:id="@+id/btnRejectVoice"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="拒绝"
            android:textSize="11sp" />

        <Button
            android:id="@+id/btnEndVoice"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="挂断"
            android:textSize="11sp" />

        <Button
            android:id="@+id/btnSpeakerphone"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="免提"
            android:textSize="11sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvP2PVoiceStatus"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="10dp"
        android:text="语音：空闲"
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessagesP2P"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="horizontal"
        android:padding="8dp">

        <EditText
            android:id="@+id/etInputP2P"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input"
            android:hint="私聊消息…"
            android:inputType="textMultiLine"
            android:maxLines="3"
            android:padding="8dp"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnSendP2P"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:backgroundTint="@color/accent"
            android:paddingHorizontal="20dp"
            android:text="发送"
            android:textColor="@color/white"
            android:textSize="14sp" />
    </LinearLayout>
</LinearLayout>
